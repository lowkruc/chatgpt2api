# ============================================
# ChatGPT2API environment variable example
# ============================================

# Auth key (required)
CHATGPT2API_AUTH_KEY=your_secret_key_here

# Base URL (optional, used to build generated image URLs)
# CHATGPT2API_BASE_URL=https://your-domain.com

# ============================================
# Storage backend config
# ============================================

# Storage backend type (options: json, sqlite, postgres, git)
# Default: json
STORAGE_BACKEND=json

# ============================================
# Database config (used when STORAGE_BACKEND=sqlite/postgres)
# ============================================

# PostgreSQL example
# DATABASE_URL=postgresql://user:password@localhost:5432/chatgpt2api

# Supabase example
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# SQLite example (auto-uses data/accounts.db when not set)
# DATABASE_URL=sqlite:///app/data/accounts.db

# ============================================
# Git repository config (used when STORAGE_BACKEND=git)
# ============================================

# Git repository URL (required)
# GIT_REPO_URL=https://github.com/your-username/your-private-repo.git

# Git access token (required)
# GitHub: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GitLab: glpat-xxxxxxxxxxxxxxxxxxxx
# GIT_TOKEN=your_git_token_here

# Git branch (optional, default: main)
# GIT_BRANCH=main

# File path inside the Git repository (optional, default: accounts.json)
# GIT_FILE_PATH=accounts.json
